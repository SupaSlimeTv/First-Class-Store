# Copy this file to .env and fill in your values
# NEVER share .env or commit it to GitHub

# Your bot token from discord.com/developers
TOKEN=your_bot_token_here

# Your Discord Application/Client ID (found on the General Information page)
CLIENT_ID=your_client_id_here

# Your Discord Server (Guild) ID — right-click your server > Copy Server ID
GUILD_ID=your_guild_id_here
